{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Absurd Running",
  "colors": {
    "primary": "#2563eb",
    "light": "#3b82f6",
    "dark": "#1d4ed8"
  },
  "favicon": "/favicon.svg",
  "appearance": {
    "default": "light"
  },
  "navigation": {
    "pages": [
      {
        "group": "Get started",
        "pages": [
          "index",
          "get-started/first-route",
          "get-started/first-plan",
          "get-started/mobile-app"
        ]
      },
      {
        "group": "Routes",
        "pages": [
          "routes/overview",
          "routes/upload-gpx",
          "routes/draw",
          "routes/import",
          "routes/checkpoints",
          "routes/share"
        ]
      },
      {
        "group": "Plans",
        "pages": [
          "plans/overview",
          "wizard/route-pace",
          "wizard/checkpoints",
          "wizard/gear",
          "wizard/fuel",
          "wizard/dropbags-tasks"
        ]
      },
      {
        "group": "Gear",
        "pages": [
          "gear/overview"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Open app",
        "href": "https://absurdrunning.com/app"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Sign up",
      "href": "https://absurdrunning.com/sign-up"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/absurdrunning"
    }
  }
}
